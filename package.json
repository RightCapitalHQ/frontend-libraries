{
  "name": "@rightcapital/libraries",
  "version": "1.0.2",
  "main": "index.js",
  "author": "RightCapital Ecosystem team <npm-publisher@rightcapital.com>",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.16.1"
  },
  "repository": "https://github.com/RightCapitalHQ/frontend-libraries",
  "scripts": {
    "build": "nx run-many -t build",
    "change": "nx release plan",
    "check": "nx release plan:check",
    "commit": "cz",
    "docs": "nx run-many -t docs",
    "fix": "pnpm run fix:eslint && pnpm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier --write .",
    "lint": "concurrently pnpm:lint:*",
    "lint:eslint": "eslint --max-warnings=0 .",
    "lint:prettier": "prettier -c .",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "test": "jest",
    "typecheck": "nx run-many -t typecheck"
  },
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "nx"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "7.23.9",
    "@babel/preset-typescript": "7.23.3",
    "@commitlint/cli": "19.0.0",
    "@commitlint/config-conventional": "19.0.0",
    "@commitlint/cz-commitlint": "19.0.0",
    "@nx/js": "22.0.2",
    "@rightcapital/eslint-config": "38.0.0",
    "@rightcapital/exceptions": "workspace:*",
    "@rightcapital/prettier-config": "6.0.12",
    "@types/jest": "29.5.11",
    "commitizen": "4.3.0",
    "concurrently": "8.2.2",
    "eslint": "9.13.0",
    "husky": "9.0.7",
    "inquirer": "9.2.13",
    "jest": "29.7.0",
    "nx": "22.0.2",
    "prettier": "3.2.4",
    "ts-node": "10.9.2",
    "typescript": "5.3.3"
  }
}
