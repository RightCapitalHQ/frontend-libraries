{
  "name": "@rightcapital/libraries",
  "version": "1.0.2",
  "main": "index.js",
  "author": "RightCapital Ecosystem team <npm-publisher@rightcapital.com>",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.16.1"
  },
  "repository": "https://github.com/RightCapitalHQ/frontend-libraries",
  "scripts": {
    "build": "nx run-many -t build",
    "change": "nx release plan",
    "check": "nx release plan:check",
    "commit": "cz",
    "docs": "nx run-many -t docs",
    "fix": "pnpm run fix:eslint && pnpm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier --write .",
    "lint": "concurrently pnpm:lint:*",
    "lint:eslint": "eslint --max-warnings=0 .",
    "lint:prettier": "prettier -c .",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "test": "jest",
    "typecheck": "nx run-many -t typecheck"
  },
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "nx"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.2",
    "@babel/preset-typescript": "7.28.5",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@commitlint/cz-commitlint": "19.8.1",
    "@nx/js": "22.6.5",
    "@rightcapital/eslint-config": "38.0.1",
    "@rightcapital/exceptions": "workspace:*",
    "@rightcapital/prettier-config": "6.0.16",
    "@types/jest": "29.5.14",
    "commitizen": "4.3.1",
    "concurrently": "8.2.2",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "inquirer": "9.3.8",
    "jest": "29.7.0",
    "nx": "22.6.5",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
